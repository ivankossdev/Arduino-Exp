void setup() {
  // Инициализируем последовательный порт со скоростью 115200 бод
  Serial.begin(115200);

  // Ждём, пока последовательный порт не станет доступен (актуально для некоторых плат)
  while (!Serial) {
    delay(100);
  }

  // Отправляем стартовое сообщение
  Serial.println("ESP32-C3 Super Mini: Последовательный порт инициализирован!");
  Serial.println("Отправка тестовых сообщений каждые 2 секунды...");
  Serial.println("---");
}

void loop() {
  // Формируем и отправляем сообщение с меткой времени
  Serial.print("Сообщение отправлено в ");
  Serial.print(millis() / 1000);  // Время в секундах с момента запуска
  Serial.println(" секунд");

  // Пауза 2 секунды перед следующим сообщением
  delay(2000);
}
